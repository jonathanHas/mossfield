APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# POS Database Connection (uniCenta)
# Uncomment and configure when ready to connect to POS system
# POS_DB_HOST=127.0.0.1
# POS_DB_PORT=3306
# POS_DB_DATABASE=unicenta
# POS_DB_USERNAME=readonly_user
# POS_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Production hardening — set these in production .env (not dev):
#   SESSION_SECURE_COOKIE=true    # only transmit session cookie over HTTPS
#   SESSION_HTTP_ONLY=true        # block JS from reading the cookie
#   SESSION_SAME_SITE=strict      # mitigate CSRF on top of the token
#   SESSION_ENCRYPT=true          # encrypt session payload at rest

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Office API Token for External Services
# Used by the online ordering service (mossorders) to access product data
# Generate a secure random token: openssl rand -hex 32
OFFICE_API_TOKEN=
# Set to the OLD token during rotation so both old and new are accepted.
# Clear once all clients have switched.
OFFICE_API_TOKEN_PREVIOUS=
# Optional caller allowlist for /api/* — comma-separated IPs and/or CIDRs.
# Blank = allow all. Example: "203.0.113.4,198.51.100.0/24".
OFFICE_API_ALLOWED_IPS=

# Mossorders Online Portal API Configuration
# Used by the office system to fetch orders from the online ordering portal
MOSSORDERS_BASE_URL="https://mossorders.example.com"
MOSSORDERS_API_TOKEN="changeme_mossorders_api_token"

# Set to true to enable the hourly scheduled sync of online orders.
# Leave false in dev and on first deploy; flip to true once logs look clean.
SYNC_SCHEDULE_ENABLED=false

# Where to email the scheduler output when a sync run fails.
# Leave blank to disable email alerts; rely on tailing storage/logs/sync.log instead.
SYNC_ALERT_EMAIL=

# Override the seeded admin password. Used by AdminUserSeeder in non-production.
# Leave unset to keep the default 'admin123' (dev only).
ADMIN_SEED_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
